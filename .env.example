# =============================================================================
# .env.example — Mutual Keep-Alive System
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# keep_alive.py — Main Pinger Service
# -----------------------------------------------------------------------------

# Comma-separated list of service URLs to ping every 14 minutes.
# Include the watcher's URL here to close the mutual keep-alive loop.
# Example: https://service-a.onrender.com,https://service-b.onrender.com,https://keep-alive-watcher.onrender.com
SITES_URLS=https://your-service-a.onrender.com,https://your-service-b.onrender.com,https://keep-alive-watcher.onrender.com

# -----------------------------------------------------------------------------
# watcher.py — Watcher Service
# -----------------------------------------------------------------------------

# Full URL of the main pinger's /health endpoint.
# Example: https://keep-alive-pinger.onrender.com/health
MAIN_PINGER_URL=https://keep-alive-pinger.onrender.com/health

# -----------------------------------------------------------------------------
# Shared / optional settings (apply to both services)
# -----------------------------------------------------------------------------

# Seconds between ping cycles. Default: 840 (14 minutes).
# Render free tier spins down after 15 min of inactivity — keep this under 900.
PING_INTERVAL=840

# Per-request timeout in seconds. Default: 15.
# Increase to 30 if cold-start timeouts appear in the logs.
REQUEST_TIMEOUT=15

# Port the Flask app listens on.
# Render injects PORT automatically — only set this for local development.
# PORT=8080
